{
  "name": "crawsecure-monorepo",
  "version": "2.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "crawsecure-monorepo",
      "version": "2.0.0",
      "license": "MIT",
      "workspaces": [
        "packages/*",
        "apps/*"
      ]
    },
    "node_modules/@crawsecure/browser": {
      "resolved": "packages/browser",
      "link": true
    },
    "node_modules/@crawsecure/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/crawsecure": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/browser": {
      "name": "@crawsecure/browser",
      "version": "2.0.0",
      "license": "MIT",
      "dependencies": {
        "@crawsecure/core": "*"
      }
    },
    "packages/cli": {
      "name": "crawsecure",
      "version": "2.0.0",
      "license": "MIT",
      "dependencies": {
        "@crawsecure/core": "*"
      },
      "bin": {
        "crawsecure": "bin/crawsecure.js"
      }
    },
    "packages/core": {
      "name": "@crawsecure/core",
      "version": "2.0.0",
      "license": "MIT"
    }
  }
}
